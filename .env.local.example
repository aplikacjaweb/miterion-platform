# Miterion Platform - Environment Variables
# Copy this file to .env.local and fill in the values

# Supabase Configuration (required for DB and storage)
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Resend Configuration (required for email)
RESEND_API_KEY=your-resend-api-key
RESEND_FROM_EMAIL=noreply@your-domain.com

# PDF Generation (optional, for Chromium path)
# CHROMIUM_EXECUTABLE_PATH=path-to-chromium-executable

# App Configuration
# NEXT_PUBLIC_APP_URL=http://localhost:3000

# Notes:
# 1. Supabase variables are required for:
#    - Database operations (lead storage)
#    - File storage (PDF uploads)
#    - API caching
# 2. Resend is required for email notifications
# 3. Without these, features will be disabled but app will run